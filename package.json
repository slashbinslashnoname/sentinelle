{
  "name": "sentinelle",
  "version": "0.1.0",
  "description": "Self-hosted Bitcoin invoicing gateway: fiat/BTC priced invoices payable on-chain (xpub/ypub/zpub) or via phoenixd Lightning, with a 15-minute payment window.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sentinelle": "dist/index.js"
  },
  "scripts": {
    "dev": "concurrently -n server,admin -c red,blue \"pnpm dev:server\" \"pnpm dev:admin\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:admin": "pnpm --filter sentinelle-admin-ui dev",
    "build": "pnpm build:admin && pnpm build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:admin": "pnpm --filter sentinelle-admin-ui build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter sentinelle-admin-ui typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@scure/base": "^1.2.4",
    "@scure/bip32": "^1.6.2",
    "@scure/btc-signer": "^1.7.0",
    "better-sqlite3": "^11.8.1",
    "exceljs": "^4.4.0",
    "hono": "^4.12.27",
    "nodemailer": "^6.10.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.24",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
