# ---------------------------------------------------------------------------
# Sentinelle BOOTSTRAP configuration.
#
# Only the few values needed to start the process and protect the admin API
# live here. EVERYTHING operational — xpub/ypub/zpub, phoenixd, block explorer,
# exchange rates, invoice TTL, CORS origins and SMTP/email — is configured at
# runtime through the admin settings API and stored in the database.
#
# Copy to `.env` and edit. Never commit `.env`.
# ---------------------------------------------------------------------------

# HTTP server
PORT=8080
HOST=127.0.0.1

# Admin dashboard / admin API password (HTTP Basic, username ignored).
# This is the master credential — it guards the settings API itself, so it must
# come from the environment and not from the settings it protects.
ADMIN_PASSWORD=change-me-admin

# API key the shop sends to create invoices (header: x-api-key).
# Leave empty to reuse ADMIN_PASSWORD as the key.
MERCHANT_API_KEY=change-me-merchant

# SQLite database file (holds invoices AND all operational settings).
DATABASE_PATH=./data/sentinelle.sqlite

# ---------------------------------------------------------------------------
# Everything else is set via the admin API, e.g.:
#
#   curl -u :$ADMIN_PASSWORD -X PUT http://127.0.0.1:8080/api/admin/settings \
#     -H 'content-type: application/json' \
#     -d '{
#           "bitcoin_xpub": "zpub6r...",
#           "phoenixd_url": "http://127.0.0.1:9740",
#           "phoenixd_password": "...",
#           "explorer_url": "https://mempool.space",
#           "invoice_ttl_seconds": 900,
#           "cors_origins": "https://shop.example.com",
#           "smtp_host": "smtp.example.com",
#           "smtp_port": 587,
#           "email_to": "merchant@example.com",
#           "notify_events": "invoice.paid"
#         }'
#
# See README.md and docs/LLM.md for the full settings reference.
# ---------------------------------------------------------------------------
